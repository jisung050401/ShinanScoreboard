<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>트레센학원신안지부 스코어보드 · 컨트롤</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jua&family=Gaegu:wght@400;700&family=Noto+Sans+KR:wght@400;500;700;900&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>
<style>
  :root{
    --cream:#FFF8F1;
    --pink:#FFD6E8;
    --pink-deep:#FF9FC1;
    --lavender:#E3D9FF;
    --lavender-deep:#C6B4FF;
    --mint:#C9F5E2;
    --gold:#FFC93C;
    --silver:#D7DBE6;
    --silver-deep:#AEB4C6;
    --bronze:#E8B589;
    --bronze-deep:#CE8A55;
    --plum:#4A3358;
    --plum-soft:#7A6690;
    --white:#FFFFFF;
    --shadow: 0 6px 18px rgba(122, 90, 143, 0.14);
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:
      radial-gradient(circle at 10% 0%, #FFEAF3 0%, transparent 45%),
      radial-gradient(circle at 90% 10%, #EDE6FF 0%, transparent 45%),
      var(--cream);
    font-family:'Noto Sans KR', sans-serif;
    color:var(--plum);
    min-height:100vh;
    padding:0 0 60px 0;
  }
  .header{
    position:relative;
    background:linear-gradient(120deg, var(--lavender) 0%, var(--pink) 100%);
    padding:30px 20px 40px;
    overflow:hidden;
    text-align:center;
  }
  .header::before{
    content:"";
    position:absolute; inset:0;
    background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.35) 0 12px, transparent 12px 26px);
    opacity:0.5;
  }
  .header .eyebrow{
    position:relative; font-family:'Gaegu', sans-serif; font-weight:700;
    font-size:15px; letter-spacing:2px; color:var(--plum); opacity:0.75; margin-bottom:6px;
  }
  .header h1{
    position:relative; font-family:'Jua', sans-serif; font-size:clamp(24px, 4vw, 34px);
    margin:0; color:var(--plum); text-shadow: 2px 2px 0 rgba(255,255,255,0.6); letter-spacing:1px;
  }
  .header .sub{ position:relative; margin-top:8px; font-size:13px; color:var(--plum-soft); font-weight:500; }
  .track-edge{
    position:absolute; left:0; right:0; bottom:0; height:14px;
    background: repeating-linear-gradient(90deg, var(--white) 0 22px, transparent 22px 44px); opacity:0.8;
  }
  .wrap{ max-width:640px; margin:0 auto; padding:0 18px; }

  .config-warning{
    max-width:640px; margin:16px auto 0; padding:14px 18px;
    background:#FFF3CD; border:2px solid #F5C451; border-radius:14px;
    color:#7A5A00; font-size:13px; line-height:1.6;
  }
  .config-warning code{ background:rgba(0,0,0,0.06); padding:1px 5px; border-radius:5px; }

  .add-card{
    background:var(--white); border-radius:20px; box-shadow:var(--shadow); padding:16px;
    margin-top:-24px; position:relative; display:flex; gap:8px;
  }
  .add-card input{
    flex:1; border:2px solid #F1E7FB; border-radius:14px; padding:12px 14px; font-size:15px;
    font-family:'Noto Sans KR', sans-serif; outline:none; color:var(--plum); background:#FFFDFB;
  }
  .add-card input:focus{border-color:var(--pink-deep);}
  .add-card button{
    border:none; border-radius:14px; padding:0 20px; font-family:'Jua', sans-serif; font-size:15px;
    background:linear-gradient(135deg, var(--pink-deep), var(--lavender-deep)); color:#fff; cursor:pointer;
    box-shadow:0 4px 10px rgba(198,150,220,0.4); transition:transform .12s ease; white-space:nowrap;
  }
  .add-card button:active{transform:scale(0.95);}

  .search-card{
    background:var(--white); border-radius:16px; box-shadow:var(--shadow); padding:10px 14px;
    margin-top:10px; display:flex; align-items:center; gap:8px;
  }
  .search-icon{ font-size:14px; opacity:0.6; flex:0 0 auto; }
  .search-card input{
    flex:1; border:none; outline:none; font-size:14px; font-family:'Noto Sans KR', sans-serif;
    color:var(--plum); background:transparent; min-width:0;
  }
  .search-card input::placeholder{color:#C7BBD9;}
  .search-clear{
    border:none; background:#F3EEFB; color:var(--plum-soft); width:22px; height:22px; border-radius:50%;
    font-size:12px; cursor:pointer; flex:0 0 auto; display:flex; align-items:center; justify-content:center;
  }
  .search-clear:hover{background:var(--pink); color:var(--plum);}

  .toolbar{
    display:flex; justify-content:space-between; align-items:center; margin-top:22px; margin-bottom:10px;
    padding:0 4px; flex-wrap:wrap; gap:6px;
  }
  .toolbar .count{ font-size:13px; color:var(--plum-soft); font-weight:500; }
  .toolbar .reset-btn{
    border:none; background:none; color:var(--plum-soft); font-size:13px; text-decoration:underline;
    cursor:pointer; font-family:'Noto Sans KR', sans-serif;
  }
  .toolbar .reset-btn:hover{color:var(--pink-deep);}
  .toolbar .toolbar-actions{ display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
  .toolbar .register-check-btn{
    border:none; border-radius:10px; padding:7px 12px; font-size:12.5px; font-weight:700; cursor:pointer;
    background:#EFF1FB; color:#4B5AAE; font-family:'Noto Sans KR', sans-serif;
  }
  .toolbar .register-check-btn:hover{ background:var(--lavender); }

  /* ---- modal ---- */
  .modal-overlay{
    position:fixed; inset:0; background:rgba(74,51,88,0.45); z-index:50;
    display:none; align-items:center; justify-content:center; padding:18px;
  }
  .modal-card{
    background:var(--white); border-radius:22px; box-shadow:0 14px 40px rgba(74,51,88,0.3);
    width:100%; max-width:380px; padding:26px 22px 22px; position:relative; text-align:center;
    max-height:88vh; overflow-y:auto;
  }
  .modal-card.wide{ max-width:480px; text-align:left; }
  .modal-close{
    position:absolute; top:14px; right:14px; border:none; background:#F3EEFB; color:var(--plum-soft);
    width:28px; height:28px; border-radius:50%; cursor:pointer; font-size:13px; line-height:1;
  }
  .modal-close:hover{ background:var(--pink); color:var(--plum); }
  .modal-title{ font-family:'Jua', sans-serif; font-size:18px; color:var(--plum); margin:4px 0 6px; text-align:center; }
  .modal-card.wide .modal-title{ text-align:left; }
  .modal-desc{ font-size:13px; color:var(--plum-soft); line-height:1.5; margin-bottom:16px; text-align:center; }
  .modal-card.wide .modal-desc{ text-align:left; }
  .modal-desc.small{ font-size:12px; margin-bottom:8px; }
  .modal-input{
    border:2px solid #F1E7FB; border-radius:12px; padding:10px 12px; font-size:14px;
    font-family:'Noto Sans KR', sans-serif; outline:none; color:var(--plum); background:#FFFDFB;
    box-sizing:border-box;
  }
  .modal-input:focus{ border-color:var(--pink-deep); }
  .modal-error{ min-height:16px; font-size:12px; color:#B8305B; margin:6px 0 4px; font-weight:600; }
  .modal-error.success{ color:#1C7A4E; }
  .modal-btn{
    border:none; border-radius:12px; padding:10px 16px; font-family:'Jua', sans-serif; font-size:14px;
    background:linear-gradient(135deg, var(--pink-deep), var(--lavender-deep)); color:#fff; cursor:pointer;
    box-shadow:0 4px 10px rgba(198,150,220,0.4); transition:transform .12s ease; white-space:nowrap;
  }
  .modal-btn:active{ transform:scale(0.95); }
  .modal-btn.small{ padding:9px 14px; font-size:13px; }
  .modal-btn.danger{ background:linear-gradient(135deg, #E8517A, #C6396B); }
  .modal-empty{ padding:24px 10px; color:var(--plum-soft); font-size:13px; text-align:center; }

  .register-list{ display:flex; flex-direction:column; gap:8px; max-height:280px; overflow-y:auto; margin-bottom:20px; }
  .register-row{
    display:flex; align-items:center; gap:8px; background:#FBF8FF; border-radius:12px; padding:9px 12px;
  }
  .register-name{ font-family:'Jua', sans-serif; font-size:14px; color:var(--plum); flex:1 1 auto; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .register-code{ font-family:'Gaegu', sans-serif; font-size:15px; font-weight:700; color:var(--plum); letter-spacing:1px; flex:0 0 auto; }
  .register-code.empty{ font-family:'Noto Sans KR', sans-serif; font-weight:500; font-size:12px; color:#C7BBD9; }
  .copy-btn{
    border:none; border-radius:8px; padding:5px 9px; font-size:11px; font-weight:700; cursor:pointer;
    background:var(--mint); color:#1C7A4E; flex:0 0 auto; font-family:'Noto Sans KR', sans-serif;
  }
  .copy-btn:hover{ background:#AEEBCE; }

  .security-section{ border-top:1px solid #F1E7FB; padding-top:14px; margin-top:14px; }
  .security-section-title{ font-family:'Jua', sans-serif; font-size:14.5px; color:var(--plum); margin-bottom:6px; }
  .security-row{ display:flex; gap:8px; }
  .security-row .modal-input{ flex:1; min-width:0; }
  .save-status{
    font-size:12px; font-weight:600; color:var(--plum-soft); display:flex; align-items:center; gap:5px;
    opacity:0; transition:opacity .25s ease;
  }
  .save-status.show{opacity:1;}
  .save-status.saving{color:var(--plum-soft);}
  .save-status.saved{color:#1C7A4E;}
  .save-status.error{color:#B8305B;}
  .save-status .dot{ width:7px; height:7px; border-radius:50%; background:currentColor; flex:0 0 auto; }
  .save-status.saving .dot{ animation:pulse 1s ease-in-out infinite; }
  @keyframes pulse{ 0%,100%{opacity:1; transform:scale(1);} 50%{opacity:0.4; transform:scale(0.7);} }

  .order-note{
    font-size:12px; color:var(--plum-soft); background:#F3EEFB; border-radius:10px;
    padding:8px 12px; margin-bottom:10px; text-align:center;
  }

  .empty{
    text-align:center; padding:60px 20px; color:var(--plum-soft); background:var(--white);
    border-radius:20px; box-shadow:var(--shadow);
  }
  .empty .icon{font-size:40px; margin-bottom:10px;}
  .empty .msg{font-family:'Jua', sans-serif; font-size:17px; color:var(--plum);}
  .empty .hint{font-size:13px; margin-top:6px;}

  #lanes{ display:flex; flex-direction:column; gap:12px; }
  .lane{
    position:relative; background:var(--white); border-radius:18px; box-shadow:var(--shadow);
    padding:14px 16px; display:flex; align-items:center; gap:12px; overflow:hidden; border:2px solid transparent;
  }
  .badge{
    position:relative; z-index:1; flex:0 0 auto; width:38px; height:38px; border-radius:50%;
    display:flex; align-items:center; justify-content:center; font-family:'Gaegu', sans-serif;
    font-weight:700; font-size:13px; background:var(--lavender); color:var(--plum); text-align:center; line-height:1.1;
  }
  .badge .r1{font-size:15px;}
  .badge.top1{background:var(--gold); color:#7A4B00;}
  .badge.top2{background:var(--silver); color:#4a5066;}
  .badge.top3{background:var(--bronze); color:#6a3d1a;}

  .lane-main{ position:relative; z-index:1; flex:1 1 auto; min-width:0; }
  .lane-name{
    font-family:'Jua', sans-serif; font-size:16.5px; color:var(--plum); white-space:nowrap;
    overflow:hidden; text-overflow:ellipsis; display:flex; align-items:center; gap:5px; cursor:text;
  }
  .lane-score{ font-size:13px; color:var(--plum-soft); font-weight:700; margin-top:2px; }
  .lane-score b{ color:var(--plum); font-size:16px; font-family:'Gaegu', sans-serif; }

  .lane-controls{
    position:relative; z-index:1; display:flex; align-items:center; gap:4px; flex:0 0 auto;
    flex-wrap:wrap; justify-content:flex-end;
  }
  .chip{
    border:none; border-radius:10px; padding:6px 8px; font-size:12px; font-weight:700; cursor:pointer;
    background:#F3EEFB; color:var(--plum); transition:transform .1s ease, background .15s ease;
    font-family:'Noto Sans KR', sans-serif;
  }
  .chip:hover{background:var(--lavender);}
  .chip:active{transform:scale(0.9);}
  .chip.plus{background:#E4F9EE; color:#1C7A4E;}
  .chip.plus:hover{background:var(--mint);}
  .chip.edit{background:#EFF1FB; color:#4B5AAE; padding:6px 7px;}
  .chip.edit:hover{background:var(--lavender);}

  .rename-input{
    width:100%; max-width:180px; border:1.5px solid var(--pink-deep); border-radius:8px; padding:3px 8px;
    font-size:15px; font-family:'Jua', sans-serif; color:var(--plum); outline:none; background:#FFFDFB;
  }

  .custom-form{ display:flex; align-items:center; gap:3px; }
  .custom-form input{
    width:46px; border:1.5px solid #EEE2FA; border-radius:8px; padding:6px 4px; font-size:12px;
    text-align:center; font-family:'Noto Sans KR', sans-serif; outline:none;
  }
  .custom-form input:focus{border-color:var(--pink-deep);}
  .custom-form button{
    border:none; border-radius:8px; padding:6px 8px; font-size:11px; font-weight:700;
    background:var(--plum); color:#fff; cursor:pointer;
  }

  .del-btn{
    border:none; background:none; color:#D8C6E4; font-size:16px; cursor:pointer; padding:2px 4px;
    line-height:1; transition:color .15s ease;
  }
  .del-btn:hover{color:#E8517A;}

  @media (max-width:480px){
    .lane{flex-wrap:wrap;}
    .lane-controls{width:100%; margin-top:6px;}
  }
</style>
</head>
<body>

  <div class="header">
    <div class="eyebrow">TRACEN ACADEMY · SINAN BRANCH</div>
    <h1>스코어보드 컨트롤</h1>
    <div class="sub">✏️ 점수 입력 · 이름 수정 전용 (순서 고정) · 실시간 동기화</div>
    <div class="track-edge"></div>
  </div>

  <div id="configWarning" class="config-warning" style="display:none;">
    ⚠️ Firebase 설정이 아직 안 되어있어요. 이 파일 맨 아래 스크립트에서 <code>firebaseConfig</code> 부분을
    본인의 Firebase 프로젝트 설정값으로 바꿔주세요. 그 전까지는 저장이 되지 않습니다.
  </div>

  <div class="wrap">
    <div class="add-card">
      <input id="nameInput" type="text" placeholder="선수 이름을 입력하세요" maxlength="20">
      <button id="addBtn">+ 선수 추가</button>
    </div>

    <div class="search-card">
      <span class="search-icon">🔍</span>
      <input id="searchInput" type="text" placeholder="이름 앞글자로 검색 (예: '김' 입력 시 '김철수' 검색)" maxlength="20">
      <button id="searchClearBtn" class="search-clear" style="display:none;" title="검색 지우기">✕</button>
    </div>

    <div class="toolbar">
      <span class="count" id="countLabel">참가자 0명</span>
      <span class="save-status" id="saveStatus"></span>
      <div class="toolbar-actions">
        <button class="register-check-btn" id="registerCheckBtn">🏇 주자등록 확인</button>
        <button class="reset-btn" id="resetBtn">전체 점수 초기화</button>
      </div>
    </div>

    <div class="order-note">📌 이 목록은 등록 순서로 고정되어 있어 점수를 바꿔도 위치가 바뀌지 않아요. 실시간 순위는 메인 보드에서 확인하세요.</div>

    <div id="lanes"></div>
    <div class="empty" id="emptyState" style="display:none;">
      <div class="icon">🏆</div>
      <div class="msg">아직 등록된 선수가 없어요</div>
      <div class="hint">위에서 이름을 입력하고 선수를 추가해보세요</div>
    </div>
  </div>

  <!-- 주자등록 확인 모달 -->
  <div id="registerModal" class="modal-overlay">
    <div class="modal-card wide">
      <button class="modal-close" id="registerModalCloseBtn">✕</button>
      <div class="modal-title">🏇 주자등록 현황</div>
      <div class="modal-desc">참가자별로 등록된 주자코드를 확인하고 복사할 수 있어요</div>

      <div id="registerList" class="register-list"></div>

      <div class="security-section">
        <div class="security-section-title">🔑 보안코드 설정</div>
        <div class="modal-desc small">주자등록 화면에서 사용할 보안코드예요. (기본값: 0000)</div>
        <div class="security-row">
          <input type="text" id="newSecurityCodeInput" class="modal-input" placeholder="새 보안코드 입력" inputmode="numeric" autocomplete="off">
          <button class="modal-btn small" id="saveSecurityBtn">저장</button>
        </div>
        <div class="modal-error" id="securitySaveMsg"></div>
      </div>

      <div class="security-section">
        <div class="security-section-title">♻️ 주자등록 초기화</div>
        <div class="modal-desc small">모든 선수의 주자코드를 한 번에 삭제해요. 보안코드 입력이 필요해요.</div>
        <div class="security-row">
          <input type="password" id="resetSecurityInput" class="modal-input" placeholder="보안코드 입력" inputmode="numeric" autocomplete="off">
          <button class="modal-btn small danger" id="resetRegisterBtn">초기화</button>
        </div>
        <div class="modal-error" id="resetRegisterMsg"></div>
      </div>
    </div>
  </div>

<script>
/* ======================================================================
   ⚙️ 여기에 본인의 Firebase 프로젝트 설정값을 붙여넣으세요.
   Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱(웹 앱) 에서 확인 가능합니다.
   ====================================================================== */
const firebaseConfig = {
  apiKey: "AIzaSyDI2oqW_a3UAMMDgUg6gZnlauK-MgUnKvs",
  authDomain: "scoreboard-b7985.firebaseapp.com",
  databaseURL: "https://scoreboard-b7985-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "scoreboard-b7985",
  storageBucket: "scoreboard-b7985.firebasestorage.app",
  messagingSenderId: "187026388744",
  appId: "1:187026388744:web:692c925fed7ede313b5ebd"
};
/* ====================================================================== */

const isConfigured = firebaseConfig.apiKey !== "YOUR_API_KEY";

let players = [];
let isEditingName = false;
let searchTerm = '';
let saveStatusTimer = null;
let playersRef = null;
let configRef = null;

function setSaveStatus(state){
  const el = document.getElementById('saveStatus');
  if(!el) return;
  el.classList.remove('saving','saved','error');
  clearTimeout(saveStatusTimer);
  if(state === 'saving'){
    el.classList.add('show','saving');
    el.innerHTML = '<span class="dot"></span>저장 중...';
  }else if(state === 'saved'){
    el.classList.add('show','saved');
    const time = new Date().toLocaleTimeString('ko-KR', {hour:'2-digit', minute:'2-digit'});
    el.innerHTML = `<span class="dot"></span>저장됨 · ${time}`;
    saveStatusTimer = setTimeout(() => el.classList.remove('show'), 2000);
  }else if(state === 'error'){
    el.classList.add('show','error');
    el.innerHTML = '<span class="dot"></span>저장 실패 · 인터넷 연결을 확인하세요';
  }
}

function roundScore(n){ return Math.round(n * 10) / 10; }

function initFirebase(){
  if(!isConfigured){
    document.getElementById('configWarning').style.display = 'block';
    render();
    return;
  }
  firebase.initializeApp(firebaseConfig);
  playersRef = firebase.database().ref('scoreboard/players');
  configRef = firebase.database().ref('scoreboard/config');

  playersRef.on('value', (snapshot) => {
    const arr = [];
    snapshot.forEach((child) => {
      const v = child.val() || {};
      arr.push({ id: child.key, name: v.name || '', score: typeof v.score === 'number' ? v.score : 0, runnerCode: v.runnerCode || '' });
    });
    players = arr;
    if(!isEditingName) render();
    if(document.getElementById('registerModal').style.display === 'flex') renderRegisterList();
  }, (err) => {
    console.error('동기화 오류', err);
    setSaveStatus('error');
  });
}

function addPlayer(name){
  name = name.trim();
  if(!name || !playersRef) return;
  setSaveStatus('saving');
  playersRef.push({ name, score: 0 })
    .then(() => setSaveStatus('saved'))
    .catch((e) => { console.error(e); setSaveStatus('error'); });
}

function removePlayer(id){
  if(!playersRef) return;
  setSaveStatus('saving');
  playersRef.child(id).remove()
    .then(() => setSaveStatus('saved'))
    .catch((e) => { console.error(e); setSaveStatus('error'); });
}

function addScore(id, delta){
  if(!playersRef) return;
  setSaveStatus('saving');
  playersRef.child(id).child('score').transaction((current) => roundScore((current || 0) + delta))
    .then(() => setSaveStatus('saved'))
    .catch((e) => { console.error(e); setSaveStatus('error'); });
}

function resetAll(){
  if(players.length === 0 || !playersRef) return;
  if(!confirm('모든 선수의 점수를 0으로 초기화할까요?')) return;
  setSaveStatus('saving');
  const updates = {};
  players.forEach(p => { updates[`${p.id}/score`] = 0; });
  playersRef.update(updates)
    .then(() => setSaveStatus('saved'))
    .catch((e) => { console.error(e); setSaveStatus('error'); });
}

function renamePlayer(id, newName){
  newName = newName.trim();
  const p = players.find(p => p.id === id);
  if(!p || !newName || newName === p.name || !playersRef) return false;
  setSaveStatus('saving');
  playersRef.child(id).child('name').set(newName)
    .then(() => setSaveStatus('saved'))
    .catch((e) => { console.error(e); setSaveStatus('error'); });
  return true;
}

function computeRankMap(){
  const ranked = [...players].sort((a,b) => b.score - a.score);
  const map = new Map();
  ranked.forEach((p, idx) => map.set(p.id, idx + 1));
  return map;
}

function getFilteredPlayers(){
  const term = searchTerm.trim().toLowerCase();
  if(!term) return players;
  return players.filter(p => p.name.toLowerCase().startsWith(term));
}

function escapeHtml(str){
  return str.replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

function render(){
  const lanesEl = document.getElementById('lanes');
  const emptyEl = document.getElementById('emptyState');
  const countLabel = document.getElementById('countLabel');

  const filtered = getFilteredPlayers();
  const searching = searchTerm.trim().length > 0;

  countLabel.textContent = searching
    ? `검색 결과 ${filtered.length}명 / 전체 ${players.length}명`
    : `참가자 ${players.length}명`;

  if(players.length === 0){
    lanesEl.innerHTML = '';
    emptyEl.style.display = 'block';
    emptyEl.querySelector('.icon').textContent = '🏆';
    emptyEl.querySelector('.msg').textContent = '아직 등록된 선수가 없어요';
    emptyEl.querySelector('.hint').textContent = '위에서 이름을 입력하고 선수를 추가해보세요';
    return;
  }

  if(searching && filtered.length === 0){
    lanesEl.innerHTML = '';
    emptyEl.style.display = 'block';
    emptyEl.querySelector('.icon').textContent = '🔍';
    emptyEl.querySelector('.msg').textContent = '검색 결과가 없어요';
    emptyEl.querySelector('.hint').textContent = `'${escapeHtml(searchTerm.trim())}'(으)로 시작하는 이름이 없어요`;
    return;
  }
  emptyEl.style.display = 'none';

  const rankMap = computeRankMap();

  lanesEl.innerHTML = filtered.map((p) => {
    const rank = rankMap.get(p.id);
    const topClass = rank === 1 ? 'top1' : rank === 2 ? 'top2' : rank === 3 ? 'top3' : '';
    const rankLabel = rank <= 3 ? ['🥇','🥈','🥉'][rank-1] : `${rank}위`;

    return `
      <div class="lane" data-id="${p.id}">
        <div class="badge ${topClass}"><span class="${rank<=3?'r1':''}">${rankLabel}</span></div>
        <div class="lane-main">
          <div class="lane-name" ondblclick="startRename('${p.id}')" title="더블클릭으로 이름 변경">${escapeHtml(p.name)}</div>
          <div class="lane-score"><b>${p.score}</b> 점</div>
        </div>
        <div class="lane-controls">
          <button class="chip plus" onclick="addScore('${p.id}', 0.1)">+0.1</button>
          <button class="chip plus" onclick="addScore('${p.id}', 0.3)">+0.3</button>
          <button class="chip plus" onclick="addScore('${p.id}', 0.7)">+0.7</button>
          <button class="chip plus" onclick="addScore('${p.id}', 1)">+1</button>
          <form class="custom-form" onsubmit="return handleCustomAdd(event, '${p.id}')">
            <input type="number" step="0.1" placeholder="직접" />
            <button type="submit">추가</button>
          </form>
          <button class="chip edit" title="이름 변경" onclick="startRename('${p.id}')">✏️</button>
          <button class="del-btn" title="선수 삭제" onclick="confirmRemove('${p.id}', '${escapeHtml(p.name)}')">✕</button>
        </div>
      </div>
    `;
  }).join('');
}

function handleCustomAdd(evt, id){
  evt.preventDefault();
  const input = evt.target.querySelector('input');
  const val = parseFloat(input.value);
  if(!isNaN(val) && val !== 0){
    addScore(id, val);
  }
  input.value = '';
  return false;
}

function confirmRemove(id, name){
  if(confirm(`${name} 선수를 명단에서 삭제할까요?`)){
    removePlayer(id);
  }
}

function startRename(id){
  const laneEl = document.querySelector(`.lane[data-id="${id}"]`);
  const player = players.find(p => p.id === id);
  if(!laneEl || !player) return;

  isEditingName = true;
  const nameEl = laneEl.querySelector('.lane-name');
  nameEl.innerHTML = `<input type="text" class="rename-input" maxlength="20" value="${escapeHtml(player.name)}">`;
  const input = nameEl.querySelector('input');
  input.focus();
  input.select();

  let done = false;
  const commit = () => {
    if(done) return;
    done = true;
    isEditingName = false;
    const changed = renamePlayer(id, input.value);
    if(!changed) render();
  };
  const cancel = () => {
    if(done) return;
    done = true;
    isEditingName = false;
    render();
  };

  input.addEventListener('keydown', (e) => {
    if(e.key === 'Enter'){ e.preventDefault(); commit(); }
    else if(e.key === 'Escape'){ e.preventDefault(); cancel(); }
  });
  input.addEventListener('blur', commit);
}

document.getElementById('addBtn').addEventListener('click', () => {
  const input = document.getElementById('nameInput');
  addPlayer(input.value);
  input.value = '';
  input.focus();
});

document.getElementById('nameInput').addEventListener('keydown', (e) => {
  if(e.key === 'Enter'){ document.getElementById('addBtn').click(); }
});

document.getElementById('resetBtn').addEventListener('click', resetAll);

document.getElementById('searchInput').addEventListener('input', (e) => {
  searchTerm = e.target.value;
  document.getElementById('searchClearBtn').style.display = searchTerm ? 'flex' : 'none';
  render();
});

document.getElementById('searchClearBtn').addEventListener('click', () => {
  searchTerm = '';
  const input = document.getElementById('searchInput');
  input.value = '';
  document.getElementById('searchClearBtn').style.display = 'none';
  input.focus();
  render();
});

/* ---------------- 주자등록 확인 모달 ---------------- */
function renderRegisterList(){
  const el = document.getElementById('registerList');
  if(players.length === 0){
    el.innerHTML = '<div class="modal-empty">등록된 선수가 없어요</div>';
    return;
  }
  el.innerHTML = players.map(p => `
    <div class="register-row">
      <span class="register-name">${escapeHtml(p.name)}</span>
      <span class="register-code ${p.runnerCode ? '' : 'empty'}">${p.runnerCode ? escapeHtml(p.runnerCode) : '미등록'}</span>
      ${p.runnerCode ? `<button type="button" class="copy-btn" data-code="${escapeHtml(p.runnerCode)}">복사</button>` : ''}
    </div>
  `).join('');
  el.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = btn.dataset.code;
      const finish = (ok) => {
        const orig = btn.textContent;
        btn.textContent = ok ? '복사됨!' : '실패';
        setTimeout(() => { btn.textContent = orig; }, 1200);
      };
      if(navigator.clipboard && navigator.clipboard.writeText){
        navigator.clipboard.writeText(code).then(() => finish(true)).catch(() => finish(false));
      } else {
        finish(false);
      }
    });
  });
}

function loadCurrentSecurityCode(){
  if(!configRef) return;
  configRef.child('securityCode').once('value').then((snap) => {
    const code = snap.val() || '0000';
    document.getElementById('newSecurityCodeInput').placeholder = `현재 보안코드: ${code}`;
  });
}

document.getElementById('registerCheckBtn').addEventListener('click', () => {
  document.getElementById('newSecurityCodeInput').value = '';
  document.getElementById('resetSecurityInput').value = '';
  document.getElementById('securitySaveMsg').textContent = '';
  document.getElementById('resetRegisterMsg').textContent = '';
  renderRegisterList();
  loadCurrentSecurityCode();
  document.getElementById('registerModal').style.display = 'flex';
});

document.getElementById('registerModalCloseBtn').addEventListener('click', () => {
  document.getElementById('registerModal').style.display = 'none';
});

document.getElementById('registerModal').addEventListener('click', (e) => {
  if(e.target.id === 'registerModal') document.getElementById('registerModal').style.display = 'none';
});

document.getElementById('saveSecurityBtn').addEventListener('click', () => {
  const val = document.getElementById('newSecurityCodeInput').value.trim();
  const msgEl = document.getElementById('securitySaveMsg');
  if(!val){
    msgEl.textContent = '새 보안코드를 입력해주세요.';
    msgEl.className = 'modal-error';
    return;
  }
  if(!configRef){ msgEl.textContent = '연결 오류가 발생했어요.'; msgEl.className = 'modal-error'; return; }
  configRef.child('securityCode').set(val)
    .then(() => {
      msgEl.textContent = '보안코드가 저장되었어요.';
      msgEl.className = 'modal-error success';
      document.getElementById('newSecurityCodeInput').value = '';
      loadCurrentSecurityCode();
    })
    .catch(() => { msgEl.textContent = '저장 실패. 다시 시도해주세요.'; msgEl.className = 'modal-error'; });
});

document.getElementById('resetRegisterBtn').addEventListener('click', () => {
  const input = document.getElementById('resetSecurityInput');
  const msgEl = document.getElementById('resetRegisterMsg');
  const code = input.value.trim();
  if(!code){
    msgEl.textContent = '보안코드를 입력해주세요.';
    msgEl.className = 'modal-error';
    return;
  }
  if(!configRef || !playersRef){ msgEl.textContent = '연결 오류가 발생했어요.'; msgEl.className = 'modal-error'; return; }
  configRef.child('securityCode').once('value').then((snap) => {
    const stored = snap.val() || '0000';
    if(code !== stored){
      msgEl.textContent = '보안코드가 올바르지 않아요.';
      msgEl.className = 'modal-error';
      return;
    }
    if(players.length === 0){
      msgEl.textContent = '초기화할 등록 정보가 없어요.';
      msgEl.className = 'modal-error';
      return;
    }
    if(!confirm('모든 선수의 주자등록 코드를 초기화할까요? 이 작업은 되돌릴 수 없어요.')) return;
    const updates = {};
    players.forEach(p => {
      updates[`${p.id}/runnerCode`] = null;
      updates[`${p.id}/registeredAt`] = null;
    });
    playersRef.update(updates)
      .then(() => {
        msgEl.textContent = '주자등록이 초기화되었어요.';
        msgEl.className = 'modal-error success';
        input.value = '';
        renderRegisterList();
      })
      .catch(() => { msgEl.textContent = '초기화 실패. 다시 시도해주세요.'; msgEl.className = 'modal-error'; });
  });
});

initFirebase();
</script>

